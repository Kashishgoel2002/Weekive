---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Weekive — the week you imagined, the week you lived",
	description = "Weekive gently shows the space between the week you meant to live and the one you did — so the gap becomes something you understand, never something you're graded on.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#c9c6f2" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
